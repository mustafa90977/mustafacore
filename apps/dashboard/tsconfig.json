{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@wacore/shared": ["../../packages/shared/src"],
      "@wacore/wa-core": ["../../packages/wa-core/src"],
      "@wacore/commerce-core": ["../../packages/commerce-core/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "next-env.d.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../../packages/shared"
    },
    {
      "path": "../../packages/wa-core"
    },
    {
      "path": "../../packages/commerce-core"
    }
  ]
}
